# urisys-node environment — systemd EnvironmentFile format.
#
# Rules: plain KEY=value, NO `export`, NO $HOME/${...} expansion (systemd does not
# expand them). For a manual (non-systemd) shell, load it with:
#     set -a && . ~/.config/urisys/node.env && set +a
#
# Install:
#   mkdir -p ~/.config/urisys
#   cp config/node.env.example ~/.config/urisys/node.env
#
# Paths (data/events/config/browser) are NOT set here on purpose:
#   * the node defaults to XDG (~/.local/share/urisys) in code, regardless of CWD;
#   * the systemd unit sets them explicitly via %h.
# Override them here only if you must, and then use ABSOLUTE paths (no $HOME).

# --- behaviour toggles ---
URISYS_ALLOW_REAL=1
URISYS_NODE_AUTO_INSTALL=1
URISYS_PACK_SOURCE=auto
URISYS_NODE_PACKS=node,screen,shell

# --- optional overrides (absolute paths only) ---
# URISYS_NODE_DATA=/home/tom/.local/share/urisys
# URISYS_NODE_CONFIG=/home/tom/.config/urisys/node-profile.json
# URISYS_BROWSER_USER_DATA_DIR=/home/tom/.config/google-chrome/Default
# URISYS_HIM_DRIVER=ydotool

# --- secrets: prefer a separate chmod 600 file: ~/.config/urisys/secrets.env ---
# OPENROUTER_API_KEY=
