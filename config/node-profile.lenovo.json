{
  "profile_id": "urisys-node-lenovo",
  "node_id": "lenovo",
  "screen": {
    "default_backend": "auto",
    "output_dir": "data/screens"
  },
  "kvm": {
    "driver": "mss"
  },
  "him": {
    "driver": "ydotool"
  },
  "llm": {
    "driver": "litellm",
    "model": "openrouter/google/gemini-3.1-flash-image-preview"
  },
  "forwards": [
    {
      "scheme": "imgl",
      "endpoint": "http://127.0.0.1:8219",
      "patterns": [
        "imgl://{host}/image/latest/query/layout",
        "imgl://{host}/image/latest/command/execute"
      ],
      "note": "Requires external imgl service on :8219 (semcod/imgl not yet packaged as URI worker)"
    }
  ],
  "policy": {
    "require_pairing": false,
    "require_approval_for": [
      "him.*",
      "kvm.task.*",
      "screen.*.capture*",
      "mail.message.send",
      "mail.message.publish_post",
      "office.document.export_pdf",
      "browser.form.submit",
      "browser.page.open",
      "browser.social.publish_post"
    ]
  },
  "browser": {
    "driver": "system-open",
    "user_data_dir": "/home/tom/.config/urisys/chrome-cdp",
    "cdp_endpoint": "http://127.0.0.1:9222"
  },
  "kv": {
    "driver": "sqlite",
    "path": "~/.local/share/urisys/store.db"
  },
  "log": {
    "streams": {
      "events": "~/.local/share/urisys/events.jsonl",
      "node": "/tmp/urisys-node.log"
    }
  },
  "office": {
    "driver": "mock",
    "output_dir": "data/office"
  },
  "mail": {
    "driver": "mock",
    "mailpit_api": "http://127.0.0.1:8025/api/v1",
    "smtp_host": "127.0.0.1",
    "smtp_port": 1025
  }
}
